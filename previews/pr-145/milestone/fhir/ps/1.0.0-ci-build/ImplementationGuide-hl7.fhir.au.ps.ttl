         fhir:reference [ fhir:v "Bundle/aups-referral-endoconsult-autogen" ]
       ] ;
       fhir:name [ fhir:v "Joyce 07 November 2024" ] ;
       fhir:description [ fhir:v "[Referral to Specialist and Allied Health use case](uc-referral.html) example. Shows an example of a patient summary containing the medical history and current medications that is automatically generated by a clinical information system and includes the most recent information. This example is digitally signed. Example for the *AU PS Bundle* and *AU PS Composition* profiles. Patient: Joyce Johnson." ] ;
       fhir:example [
         a fhir:canonical ;
         fhir:v "http://hl7.org.au/fhir/ps/StructureDefinition/au-ps-bundle"^^xsd:anyURI ;
