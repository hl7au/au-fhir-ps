       ] ;
       fhir:name [ fhir:v "Joyce 28 October" ] ;
       fhir:description [ fhir:v "[Referral to Specialist and Allied Health use case](uc-referral.html) example. Shows an example of a patient summary containing the medical history and current medications at the time of referral that was authored by the GP through curation of a generated view of the data within their clinical information system, and was attested at the time of creation of the patient summary and signed electronically. Example for the *AU PS Bundle* and *AU PS Composition* profiles. Patient: Joyce Johnson." ] ;
       fhir:example [
         a fhir:canonical ;
