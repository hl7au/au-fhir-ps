       fhir:name [ fhir:v "Basic Summary" ] ;
       fhir:description [ fhir:v "Shows an example of a provider curated patient summary that demonstrates no known problems or disabilities, current allergies and intolerances, and current medication use. Example for the *AU PS Bundle* and *AU PS Composition* profiles. Patient: Mia Leanne Banks." ] ;
