  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ImplementationGuide hl7.fhir.au.ps</b></p><a name=\"hl7.fhir.au.ps\"> </a><a name=\"hchl7.fhir.au.ps\"> </a><h2>AUPatientSummaryImplementationGuide</h2><p>The official URL for this implementation guide is: </p><pre>http://hl7.org.au/fhir/ps/ImplementationGuide/hl7.fhir.au.ps</pre><div><p>AU Patient Summary (AU PS) is provided to support the use of patient summaries in HL7® FHIR®© in an Australian context. It complies with the requirements defined in IPS and AU Core, and sets the minimum expectations on FHIR resources to support conformance and implementation in systems.</p>\n</div></div>"^^rdf:XMLLiteral ]
