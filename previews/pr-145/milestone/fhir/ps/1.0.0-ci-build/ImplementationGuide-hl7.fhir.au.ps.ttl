       ] ;
       fhir:name [ fhir:v "No Known X" ] ;
       fhir:description [ fhir:v "Shows an example of a patient summary that demonstrates no known problems or disabilities, no known allergies and intolerances, and no known current medications. Example for the *AU PS Bundle* and *AU PS Composition* profiles. Patient: Charlotte Morris." ] ;
