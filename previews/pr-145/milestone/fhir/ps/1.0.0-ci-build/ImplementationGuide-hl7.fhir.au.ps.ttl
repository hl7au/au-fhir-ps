       ] ;
       fhir:name [ fhir:v "Jeramy 27 May" ] ;
       fhir:description [ fhir:v "[Interstate GP use case](uc-interstate.html) example. Shows an example of a patient summary authored by the patient's usual GP that was updated after a recent admission to hospital. Example for the *AU PS Bundle* and *AU PS Composition* profiles. Patient: Jeramy Ezra Banks." ] ;
