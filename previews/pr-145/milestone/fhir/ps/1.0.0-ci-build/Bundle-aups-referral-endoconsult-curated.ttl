     fhir:title [ fhir:v "Pregnancy Information" ] ;
     fhir:code [
       fhir:coding ( [
         a loinc:10162-6 ;
         fhir:system [ fhir:v "http://loinc.org"^^xsd:anyURI ] ;
         fhir:code [ fhir:v "10162-6" ]
