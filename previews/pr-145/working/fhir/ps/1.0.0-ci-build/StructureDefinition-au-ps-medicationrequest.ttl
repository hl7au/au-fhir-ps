         fhir:expression [ fhir:v "contained.meta.security.empty()" ] ;
         fhir:xpath [ fhir:v "not(exists(f:contained/*/f:meta/f:security))" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/DomainResource"^^xsd:anyURI ;
