       a fhir:string ;
       fhir:v "1.0.0-ci-build"
     ]
  ] [
     fhir:url [ fhir:v "http://hl7.org/fhir/5.0/StructureDefinition/extension-ActorDefinition.name"^^xsd:anyURI ] ;
     fhir:value [
       a fhir:string ;
       fhir:v "AUPSProducer"
     ]
